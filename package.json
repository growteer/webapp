{
	"name": "webapp",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"clean": "rm -rf .svelte-kit && rm -rf node_modules && rm -rf build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"gen": "graphql-codegen && pnpm format",
		"lint": "prettier --check . && eslint .",
		"test": "vitest --watch=false"
	},
	"devDependencies": {
		"@apollo/client": "^3.13.8",
		"@eslint/compat": "^1.3.1",
		"@eslint/js": "^9.32.0",
		"@graphql-codegen/cli": "^5.0.7",
		"@graphql-codegen/client-preset": "^4.8.3",
		"@graphql-codegen/typescript": "^4.1.6",
		"@graphql-codegen/typescript-operations": "^4.6.1",
		"@graphql-typed-document-node/core": "^3.2.0",
		"@reown/appkit": "^1.8.1",
		"@reown/appkit-adapter-solana": "^1.8.1",
		"@skeletonlabs/skeleton": "^3.1.7",
		"@skeletonlabs/skeleton-svelte": "^1.3.1",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.26.1",
		"@sveltejs/vite-plugin-svelte": "^6.1.0",
		"@tailwindcss/vite": "^4.1.11",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.8",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^24.1.0",
		"@vitest/browser": "^3.2.4",
		"@vitest/coverage-v8": "^3.2.4",
		"eslint": "^9.32.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.11.0",
		"globals": "^16.3.0",
		"graphql": "^16.11.0",
		"happy-dom": "^18.0.1",
		"lucide-svelte": "^0.525.0",
		"msw": "^2.7.3",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"process": "^0.11.10",
		"svelte": "^5.36.16",
		"svelte-check": "^4.3.0",
		"svelte-i18n": "^4.0.1",
		"tailwindcss": "^4.1.11",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.38.0",
		"vite": "^7.0.6",
		"vite-plugin-node-polyfills": "^0.24.0",
		"vitest": "^3.2.4",
		"vitest-browser-svelte": "^1.0.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"packageManager": "pnpm@9.15.0+sha512.76e2379760a4328ec4415815bcd6628dee727af3779aaa4c914e3944156c4299921a89f976381ee107d41f12cfa4b66681ca9c718f0668fa0831ed4c6d8ba56c"
